# ═══════════════════════════════════════════════════════════════
# Autoniza Backup Manager - Configuração de Ambiente
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para config.env e preencha os valores.
#   cp config/config.env.example config/config.env

# ── Repositório Restic (S3/MinIO) ──────────────────────────────
RESTIC_REPOSITORY="s3:https://api-minio.hro.dev.br/coolifybkp"

# ── Credenciais MinIO/S3 ──────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Senha de criptografia do Restic ───────────────────────────
RESTIC_PASSWORD=""

# ── Diretório raiz do Backup Manager ──────────────────────────
BACKUP_ROOT="/opt/autoniza-backup"
